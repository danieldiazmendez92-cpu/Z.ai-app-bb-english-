# =============================================================================
# StoryEnglish Kids - Cloud Functions Environment Variables
#
# Copia este archivo a `.env` y completa los valores reales.
# Para Firebase Functions v2, las variables se cargan automaticamente desde
# `functions/.env` ( ver https://firebase.google.com/docs/functions/config-env ).
# =============================================================================

# ---- Firebase / GCP ----------------------------------------------------------
# Project ID de Firebase. En runtime viene inyectado por GCLOUD_PROJECT.
FIREBASE_PROJECT_ID=storyenglish-kids-dev
FIREBASE_STORAGE_BUCKET=storyenglish-kids-dev.appspot.com
FUNCTIONS_REGION=us-central1

# Opcional: JSON de service account de Firebase ( solo para emulador con
# credenciales custom ). En runtime de Firebase no se necesita.
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account", ...}

# ---- Gemini API --------------------------------------------------------------
# Obtener en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Modelo a utilizar ( default: gemini-1.5-flash )
GEMINI_MODEL=gemini-1.5-flash

# ---- Google Cloud Text-to-Speech --------------------------------------------
# Voces recomendadas para contenido infantil. Otros valores validos:
#   en-US-Neural2-F  ( mujer, natural, recomendado )
#   en-US-Neural2-D  ( hombre, natural )
#   en-US-Studio-Q   ( mujer, estudio, mas caro )
GOOGLE_TTS_VOICE_EN=en-US-Neural2-F
GOOGLE_TTS_VOICE_ES=es-US-Neural2-C

# ---- Google Play Developer API ----------------------------------------------
# JSON completo de la service account descargada de Google Cloud Console.
# La service account debe tener permisos de "Finance" o "View app financial
# data" en Google Play Console > Users and permissions.
PLAY_SERVICE_ACCOUNT_JSON=
# Package name de la app Android.
PLAY_PACKAGE_NAME=com.storyenglish.kids
# Secret compartido para validar webhook de RTDN ( opcional pero recomendado ).
# Configurar el mismo valor en Google Play Console > Developer options.
PLAY_WEBHOOK_SECRET=

# ---- App Store Server API ----------------------------------------------------
# Obtener en App Store Connect > Users and Access > Keys > In-App Purchase.
APP_STORE_ISSUER_ID=
APP_STORE_KEY_ID=
# Private key (.p8) en formato PEM. En el .env ponerla en una sola linea con
# \n escapados:
#   APP_STORE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIGTAgEAMBMGByqGSM49AgEGCCqGSM49AwEHBHkwdwIBAQQg...\n-----END PRIVATE KEY-----
APP_STORE_PRIVATE_KEY=
# Bundle ID de la app iOS.
APP_STORE_BUNDLE_ID=com.storyenglish.kids
# URL base. En sandbox usar https://api.storekit-sandbox.itunes.apple.com
APP_STORE_BASE_URL=https://api.storekit.itunes.apple.com
# Secret compartido para validar webhook de Server Notifications V2.
APP_STORE_WEBHOOK_SECRET=

# =============================================================================
# NOTAS:
# 1. NUNCA commitear el archivo `.env` con valores reales. Esta en .gitignore.
# 2. Para deployar variables de entorno a Firebase Cloud Functions v2:
#    firebase functions:secrets:set GEMINI_API_KEY
#    firebase functions:secrets:set PLAY_SERVICE_ACCOUNT_JSON
#    ... etc.
#    Y luego referenciarlas en el codigo con `process.env.GEMINI_API_KEY`.
# 3. Para entorno local ( emulador ), `.env` en la carpeta `functions/` se
#    carga automaticamente.
# =============================================================================
