# =============================================================================
# .env.example - Variables de entorno de ejemplo para StoryEnglish Kids
# Copia este archivo a .env (desarrollo) o configuralo via --dart-define.
# NUNCA commitear el .env real con secretos.
# =============================================================================

# ---- Flavor / ambiente ----
FLAVOR=dev

# ---- Firebase (se recomienda usar FlutterFire CLI en lugar de env vars) ----
# Estas variables se usan solo si no hay firebase_options_*.dart generado.
FIREBASE_API_KEY=
FIREBASE_APP_ID=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=

# ---- Google Cloud APIs (solo necesarias en backend, no en cliente) ----
# Se documentan aqui para referencia pero NO deben ir en la app.
GEMINI_API_KEY=
GOOGLE_TTS_API_KEY=

# ---- Feature flags / Remote Config (defaults locales) ----
MAX_CHILDREN_PROFILES=4
DEFAULT_DAILY_LIMIT_MINUTES=30
DEFAULT_AUDIO_SPEED=1.0
